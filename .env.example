# ============================================================
# obsidian-headless-sync-docker — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ---- Required -----------------------------------------------

# Auth token obtained via:
#   docker run --rm -it --entrypoint get-token <image>
OBSIDIAN_AUTH_TOKEN=

# Name of the remote Obsidian Sync vault to sync
# List available vaults:
#   docker run --rm -e OBSIDIAN_AUTH_TOKEN=... --entrypoint ob <image> sync-list-remote
# Note: --entrypoint ob bypasses s6-overlay and runs as root. This is fine for
# read-only commands, but avoid mounting config volumes as it may create
# root-owned files that conflict with the unprivileged service.
VAULT_NAME=My Vault

# Vault end-to-end encryption password (required if E2E encryption is enabled on the vault)
VAULT_PASSWORD=

# Host path where vault files should land
VAULT_HOST_PATH=./vault

# Host path for persistent config (login state, etc.)
CONFIG_HOST_PATH=./config

# ---- File ownership -----------------------------------------
#
# Controls which host user owns the synced vault files.
# The container adjusts its internal user to match at startup.
#
# Regular Docker (daemon runs as root):
#   Set to your host user's UID/GID — run `id` to find them.
#   PUID=1000
#   PGID=1000
#
# Rootless Docker / Podman:
#   Container UID 0 maps to your host user, so use:
#   PUID=0
#   PGID=0
#
PUID=1000
PGID=1000

# ---- Optional -----------------------------------------------

# Image source (override when self-building)
# GHCR_REPO=belphemur/obsidian-headless-sync-docker

# Device label shown in Obsidian Sync history
DEVICE_NAME=obsidian-docker

# Conflict resolution strategy: merge | conflict
CONFLICT_STRATEGY=merge

# Comma-separated list of vault-relative folders to exclude from sync
# Example: EXCLUDED_FOLDERS=Private,Archive
EXCLUDED_FOLDERS=

# Comma-separated extra file types to sync: image,audio,video,pdf,unsupported
# Leave blank to sync all supported types
FILE_TYPES=

# Sync mode: bidirectional (default), pull-only, mirror-remote
# pull-only  — only download remote changes, local changes are ignored
# mirror-remote — only download remote changes, local changes are reverted
SYNC_MODE=

# Comma-separated config categories to sync.
# Values: app,appearance,appearance-data,hotkey,core-plugin,core-plugin-data,community-plugin,community-plugin-data
# Leave blank to use the vault's existing setting (all categories by default).
# Set to empty string explicitly via ob sync-config to disable config syncing.
# See: https://obsidian.md/help/sync/headless#%60ob+sync-config%60
SYNC_CONFIGS=

# Override the in-container vault path (advanced; rarely needed)
# VAULT_PATH=/vault
